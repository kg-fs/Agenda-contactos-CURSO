@model AgendaContactos.Models.Contacto

@{
    ViewData["Title"] = "Nuevo Contacto";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">➕ Agregar Nuevo Contacto</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Crear" method="post">
                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan Pérez" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Telefono" class="form-label fw-bold"></label>
                            <input asp-for="Telefono" class="form-control" placeholder="Ej: 555-1234" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Celular" class="form-label fw-bold"></label>
                            <input asp-for="Celular" class="form-control" placeholder="Ej: 555-9876" />
                            <span asp-validation-for="Celular" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email" class="form-control" placeholder="Ej: correo@ejemplo.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">⬅ Volver</a>
                            <button type="submit" class="btn btn-primary">💾 Guardar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
